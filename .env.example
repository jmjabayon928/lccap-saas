# LCCAP — example environment variables (no real secrets).
# Copy to .env for local tooling if your workflow uses dotenv; ASP.NET Core also reads env vars directly.
# Comments use # prefix (shell/dotenv style).

# --- API runtime ---
ASPNETCORE_ENVIRONMENT=Development

# --- Database ---
# Application default configuration key is Postgres (see appsettings*.json). Env override:
ConnectionStrings__Postgres=Host=localhost;Port=5432;Database=lccap_dev;Username=postgres;Password=CHANGE_ME
# Common alternate name in other templates (not bound unless you add DefaultConnection to appsettings):
# ConnectionStrings__DefaultConnection=CHANGE_ME

# --- JWT / auth (dev placeholders only; rotate for any shared or production environment) ---
Jwt__Issuer=Lccap.Api.Dev
Jwt__Audience=Lccap.Client.Dev
# HS256: use a long random secret in real deployments. This string is intentionally obvious and dev-only.
Jwt__SigningKey=DEV_ONLY_HS256_SIGNING_KEY_MINIMUM_32_CHARACTERS_CHANGE_BEFORE_PRODUCTION_00000000
Jwt__ExpirationMinutes=60

# --- File storage (local dev) ---
FileStorage__RootPath=data/dev-files
FileStorage__MaxUploadBytes=10485760
FileStorage__AllowedExtensions__0=.pdf
FileStorage__AllowedExtensions__1=.docx
FileStorage__AllowedExtensions__2=.xlsx
FileStorage__AllowedExtensions__3=.png
FileStorage__AllowedExtensions__4=.jpg
FileStorage__AllowedExtensions__5=.jpeg

# --- Python AI service (planned / optional for local integration) ---
PythonAi__BaseUrl=http://localhost:8000
PythonAi__TimeoutSeconds=60
