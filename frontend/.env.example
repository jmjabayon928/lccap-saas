# Copy to `.env.local` for local overrides (never commit real secrets).
#
# Next.js exposes only variables prefixed with NEXT_PUBLIC_ to browser bundles.
# Use NEXT_PUBLIC_* only for values that are safe to disclose to clients (e.g. public API base URL).
# Never put signing keys, database passwords, or other secrets in NEXT_PUBLIC_ variables.

NEXT_PUBLIC_API_BASE_URL=http://localhost:5243
